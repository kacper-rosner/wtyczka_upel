{
  "manifest_version": 3,
  "name": "Web AI Reader",
  "version": "1.0",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
  "activeTab", 
  "scripting",
  "storage",
  "unlimitedStorage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "commands": {
    "trigger-ai": {
      "suggested_key": {
        "default": "Ctrl+Q",
        "mac": "Command+E"
      },
      "description": "Uruchom analizę AI"
    }
  }
  
}